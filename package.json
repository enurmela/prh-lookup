{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "finnish-business-lookup",
  "title": "FBL - Finnish Business Lookup",
  "description": "Look up Finnish businesses by name or Business ID using PRH YTJ open data",
  "icon": "icon.png",
  "author": "eljn",
  "access": "public",
  "categories": [
    "Productivity",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "prh-search",
      "title": "Search Finnish Businesses",
      "description": "Look up Finnish businesses by name or Business ID using PRH YTJ open data",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.20",
    "@raycast/utils": "^2.2.6"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  }
}
