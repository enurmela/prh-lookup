{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "finnish-company-search",
  "title": "Finnish Company Search",
  "description": "Search Finnish companies by name or Business ID (PRH YTJ)",
  "icon": "icon.png",
  "author": "elias",
  "access": "public",
  "categories": [
    "Productivity",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "prh-search",
      "title": "Finnish Company Search",
